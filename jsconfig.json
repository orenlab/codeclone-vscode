{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2022"
    ],
    "maxNodeModuleJsDepth": 0,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "useUnknownInCatchVariables": false,
    "types": [
      "node",
      "vscode"
    ]
  },
  "include": [
    "src/**/*.js",
    "test/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "media",
    ".vscode"
  ]
}
